<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>ModaKöşesi – Giyim & Stil</title>
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: #fafafa;
      color: #222;
      line-height: 1.7;
    }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; display: block; }
    /* ── HEADER ── */
    header {
      background: #1a1a2e;
      color: #fff;
      padding: 0 2rem;
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
      box-shadow: 0 2px 12px rgba(0,0,0,.35);
    }
    .logo {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: 1px;
      color: #e0aaff;
    }
    .logo span { color: #c77dff; }
    nav { display: flex; gap: 1.5rem; }
    nav a {
      font-size: .95rem;
      font-weight: 500;
      color: #ccc;
      transition: color .2s;
    }
    nav a:hover { color: #e0aaff; }
    /* ── HERO ── */
    .hero {
      position: relative;
      height: 520px;
      background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      color: #fff;
      overflow: hidden;
      padding: 2rem;
    }
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background: url("[images.unsplash.com](https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1400&auto=format&fit=crop)") center/cover no-repeat;
      opacity: .25;
    }
    .hero-content { position: relative; z-index: 1; max-width: 700px; }
    .hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      line-height: 1.15;
      margin-bottom: 1rem;
    }
    .hero h1 span { color: #c77dff; }
    .hero p { font-size: 1.1rem; color: #ddd; margin-bottom: 2rem; }
    .btn {
      display: inline-block;
      background: #c77dff;
      color: #fff;
      padding: .8rem 2rem;
      border-radius: 50px;
      font-weight: 700;
      font-size: 1rem;
      transition: background .25s, transform .2s;
      cursor: pointer;
    }
    .btn:hover { background: #9d4edd; transform: translateY(-2px); }
    /* ── SECTION TITLES ── */
    .section-title {
      text-align: center;
      padding: 3rem 1rem 1.5rem;
    }
    .section-title h2 {
      font-size: 2rem;
      font-weight: 800;
      color: #1a1a2e;
    }
    .section-title h2 span { color: #c77dff; }
    .section-title p { color: #666; margin-top: .4rem; }
    .divider {
      width: 60px;
      height: 4px;
      background: linear-gradient(90deg, #c77dff, #7b2ff7);
      border-radius: 4px;
      margin: .7rem auto 0;
    }
    /* ── FEATURED ARTICLES GRID ── */
    .articles {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 1.5rem 3rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 2rem;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(0,0,0,.08);
      transition: transform .3s, box-shadow .3s;
    }
    .card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,.14); }
    .card-img {
      width: 100%;
      height: 220px;
      object-fit: cover;
    }
    .card-img-placeholder {
      width: 100%;
      height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 4rem;
    }
    .card-body { padding: 1.25rem 1.5rem 1.5rem; }
    .tag {
      display: inline-block;
      background: #f0e6ff;
      color: #7b2ff7;
      font-size: .75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .8px;
      padding: .25rem .7rem;
      border-radius: 50px;
      margin-bottom: .7rem;
    }
    .card-body h3 {
      font-size: 1.15rem;
      font-weight: 800;
      margin-bottom: .5rem;
      color: #1a1a2e;
      line-height: 1.35;
    }
    .card-body p { font-size: .9rem; color: #555; margin-bottom: 1rem; }
    .card-meta {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-size: .8rem;
      color: #999;
    }
    .card-meta span { display: flex; align-items: center; gap: .25rem; }
    .read-more {
      display: inline-block;
      margin-top: .75rem;
      color: #7b2ff7;
      font-weight: 700;
      font-size: .88rem;
      transition: gap .2s;
    }
    .read-more:hover { text-decoration: underline; }
    /* ── LOOKBOOK STRIP ── */
    .lookbook-section {
      background: #1a1a2e;
      padding: 3rem 1.5rem;
    }
    .lookbook-section .section-title h2 { color: #fff; }
    .lookbook-section .section-title p { color: #aaa; }
    .lookbook-grid {
      max-width: 1200px;
      margin: 2rem auto 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
    }
    .look-item {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      aspect-ratio: 3/4;
      cursor: pointer;
    }
    .look-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform .4s;
    }
    .look-item:hover img { transform: scale(1.08); }
    .look-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.65) 0%, transparent 55%);
      display: flex;
      align-items: flex-end;
      padding: 1rem;
      color: #fff;
      font-size: .85rem;
      font-weight: 600;
    }
    .look-placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 3.5rem;
    }
    /* ── TIPS SECTION ── */
    .tips-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 1.5rem 4rem;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1.5rem;
    }
    .tip-card {
      background: linear-gradient(135deg, #f0e6ff, #fbe8ff);
      border-radius: 16px;
      padding: 1.5rem;
      text-align: center;
      border: 1px solid #e4ccff;
    }
    .tip-icon { font-size: 2.5rem; margin-bottom: .75rem; }
    .tip-card h4 { font-size: 1rem; font-weight: 800; color: #1a1a2e; margin-bottom: .4rem; }
    .tip-card p { font-size: .85rem; color: #555; }
    /* ── NEWSLETTER ── */
    .newsletter {
      background: linear-gradient(135deg, #7b2ff7, #c77dff);
      padding: 4rem 1.5rem;
      text-align: center;
      color: #fff;
    }
    .newsletter h2 { font-size: 2rem; font-weight: 900; margin-bottom: .5rem; }
    .newsletter p { font-size: 1rem; opacity: .9; margin-bottom: 2rem; }
    .nl-form {
      display: flex;
      gap: .75rem;
      justify-content: center;
      flex-wrap: wrap;
      max-width: 500px;
      margin: 0 auto;
    }
    .nl-form input {
      flex: 1;
      min-width: 220px;
      padding: .85rem 1.25rem;
      border: none;
      border-radius: 50px;
      font-size: 1rem;
      outline: none;
    }
    .nl-form button {
      background: #1a1a2e;
      color: #fff;
      border: none;
      padding: .85rem 2rem;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      transition: background .2s;
    }
    .nl-form button:hover { background: #0f0f1a; }
    /* ── FOOTER ── */
    footer {
      background: #111;
      color: #aaa;
      padding: 2.5rem 1.5rem;
      text-align: center;
    }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
      margin-bottom: 1.5rem;
      font-size: .9rem;
    }
    .footer-links a:hover { color: #c77dff; }
    footer p { font-size: .82rem; }
    .footer-logo { font-size: 1.4rem; font-weight: 800; color: #e0aaff; margin-bottom: 1rem; }
    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      nav { gap: 1rem; }
      nav a { font-size: .82rem; }
      .hero h1 { font-size: 2rem; }
    }
  </style>
</head>
